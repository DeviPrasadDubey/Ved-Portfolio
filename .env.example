# Copy to `.env.local` (Next.js) or `.env` at repo root. Never commit real values.

# SMTP (Gmail: 2-Step Verification ON, then create an App Password — NOT your normal login password)
# Paste the 16-character app password with or without spaces; spaces are stripped automatically.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=ved.hqts@gmail.com
EMAIL_PASS=mmgtcpkmegznbnij

# Sender address (often same as EMAIL_USER for Gmail)
EMAIL_FROM=ved.hqtsl@gmail.com

# Default inbox for contact form and dev test route (admin)
EMAIL_TO=vedtdp50@gmail.com

# If EMAIL_HOST is omitted, the app falls back to Nodemailer `service: "gmail"` using EMAIL_USER / EMAIL_PASS.
